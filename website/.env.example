# ── NexaSphere Website (website/) ────────────────────────────────────────────
# Copy this file to .env.local — never commit .env.local

# Base URL of the backend Express API.
# Leave empty to run in offline/localStorage mock mode (no backend needed).
# Development: http://localhost:8787
# Production:  https://nexasphere-api.up.railway.app (or your deployment URL)
VITE_API_BASE=http://localhost:8787

# URL of the admin dashboard app (used in Footer "Admin Dashboard" link).
# Development: http://localhost:5001
# Production:  https://admin.nexasphere.com
VITE_ADMIN_DASHBOARD_URL=http://localhost:5001

# Google Apps Script deployment URL for membership form submissions (optional)
VITE_MEMBERSHIP_SCRIPT_URL=

# Secret token sent with membership form submissions to verify origin (optional)
VITE_MEMBERSHIP_SECRET=

# VAPID public key for push notification subscription (optional)
VITE_VAPID_PUBLIC_KEY=

# Optional: Base path override for GitHub Pages deployments (default: /)
VITE_BASE_PATH=/

# Sentry DSN for error tracking (optional — leave blank to disable)
VITE_SENTRY_DSN=


# ── Notes ────────────────────────────────────────────────────────────────────
# VITE_API_BASE empty    → app runs in offline mode (localStorage mock DB)
# VITE_MEMBERSHIP_SCRIPT_URL empty → membership forms use direct backend proxy
# Admin dashboard is a separate Vite project (admin-dashboard/) with its own .env.local
# Backend environment variables → see server/.env.example
